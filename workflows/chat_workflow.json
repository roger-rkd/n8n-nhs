                                         "functionCode":  "const content = $json?.choices?.[0]?.message?.content;\nif (!content || typeof content !== \u0027string\u0027) {\n  throw new Error(\u0027Groq response missing assistant content\u0027);\n}\n\nreturn [\n  {\n    json: {\n      response: content\n    }\n  }\n];"
                                     },
