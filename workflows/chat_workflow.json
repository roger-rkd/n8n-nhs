                                         "bodyParametersJson":  "={\"model\":\"llama-3.3-70b-versatile\",\"messages\":[{\"role\":\"system\",\"content\":\"You are an NHS-safe virtual health assistant.\\nUse ONLY the NHS context provided below when giving advice.\\n\\nNHS Context:\\n{{$json.nhs_context}}\"},{\"role\":\"user\",\"content\":\"Conversation history: {{$json.history ? JSON.stringify($json.history) : \u0027[]\u0027}}\\n\\nUser message: {{$json.message}}\"}]}",
